# domain for TLS (Let's Encrypt)
SHOP_DOMAIN=shop.example.com

# cold storage address — payments forwarded here after confirmation
# leave empty to skip forwarding
FORWARD_ADDRESS=

# webhook for remote frontend (optional, leave empty for file-only)
WEBHOOK_URL=
WEBHOOK_SECRET=

# sync interval in seconds (default 300 = 5 min)
SYNC_INTERVAL=300
