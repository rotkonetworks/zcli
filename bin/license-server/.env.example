# license-server config. copy to `.env` and fill in. CLI flags override env.

# -----------------------------------------------------------------------------
# ZCLI_SIGNING_KEY — required. 32-byte hex ed25519 seed.
#
# the license-server signs each license with the ed25519 key derived from this
# seed. zafu verifies the signature against a hardcoded pubkey constant named
# `ROTKO_ZCASH_VERIFIER` (packages/wallet/src/rotko-verifier.ts).
#
# ⇒ the ed25519 pubkey derived from this seed MUST equal ROTKO_ZCASH_VERIFIER.
#
# to generate a fresh keypair:
#   openssl rand -hex 32                          # → write this hex to ZCLI_SIGNING_KEY
#   # then compute the pubkey (python, node, or any ed25519 tool), e.g.:
#   python3 -c 'import nacl.signing, sys; \
#     sk=nacl.signing.SigningKey(bytes.fromhex(sys.argv[1])); \
#     print(bytes(sk.verify_key).hex())' <the-seed-hex>
#   # paste that pubkey into zafu's ROTKO_ZCASH_VERIFIER constant and rebuild.
#
# if left empty, licenses are unsigned (dev mode only).
ZCLI_SIGNING_KEY=

# -----------------------------------------------------------------------------
# LICENSE_FVK — required. 96-byte hex Orchard FullViewingKey.
#
# this FVK belongs to the Zcash wallet that owns the address users send ZEC
# payments to. that address is hardcoded in zafu as `ROTKO_LICENSE_ADDRESS`
# (packages/wallet/src/license.ts). license-server decrypts inbound Orchard
# notes with this FVK to extract the `zid{}` memos that credit pro licenses.
#
# to export it from a zcli wallet:
#   zcli view export
#   # → prints "full viewing key: <96-byte-hex>"
#
# any wallet deriving the same Orchard spending key can produce this FVK.
# NEVER put the spending key here — the FVK is view-only and sufficient.
LICENSE_FVK=

# -----------------------------------------------------------------------------
# ZIDECAR_URL — zidecar gRPC endpoint. public instance by default.
#ZIDECAR_URL=https://zcash.rotko.net

# -----------------------------------------------------------------------------
# LICENSE_LISTEN — HTTP bind address for the license API.
# zafu's state/license.ts LICENSE_SERVER constant must point here.
#LICENSE_LISTEN=0.0.0.0:3334

# -----------------------------------------------------------------------------
# LICENSE_DB_PATH — sled DB where scan progress + credited licenses persist.
# wiped on /tmp reboot if you put it under /tmp.
#LICENSE_DB_PATH=./license.db

# -----------------------------------------------------------------------------
# LICENSE_FRIENDS_FILE — optional. one ZID pubkey (hex) per line, # for
# comments. pubkeys listed here get pro for free, no payment needed. useful
# for testers and dev accounts.
#LICENSE_FRIENDS_FILE=./friends.txt

# -----------------------------------------------------------------------------
# LICENSE_SCAN_INTERVAL — seconds between chain rescans.
#LICENSE_SCAN_INTERVAL=30

# -----------------------------------------------------------------------------
# LICENSE_SYNC_FROM — skip blocks before this height on the first sync.
# ignored once the DB has a saved sync height. useful when the license wallet
# has a known birthday block (cuts initial rescan time).
#LICENSE_SYNC_FROM=3300000
